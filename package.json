{
  "name": "meta-toolkit",
  "description": "Zero-dependency toolkit for meta programming and OOP: name-casing conversions, property descriptors, aliases, prototype traversal, iterators, deep path access, option merging, and comparator adapters",
  "version": "1.1.6",
  "type": "module",
  "main": "./src/aliases.js",
  "types": "./src/aliases.d.ts",
  "exports": {
    "./*": "./src/*"
  },
  "scripts": {
    "start": "tape6-server --trace",
    "test": "tape6 --flags FO",
    "test:bun": "tape6-bun --flags FO",
    "test:deno": "tape6-deno --flags FO",
    "test:proc": "tape6-proc --flags FO",
    "test:proc:bun": "bun run `tape6-proc --self` --flags FO",
    "test:proc:deno": "deno run -A `tape6-proc --self` --flags FO -r -A",
    "test:seq": "tape6-seq --flags FO",
    "test:seq:bun": "bun run `tape6-seq --self` --flags FO",
    "test:seq:deno": "deno run -A `tape6-seq --self` --flags FO",
    "ts-check": "tsc --noEmit",
    "lint": "prettier --check .",
    "lint:fix": "prettier --write ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uhop/meta-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/uhop/meta-toolkit/issues"
  },
  "homepage": "https://github.com/uhop/meta-toolkit#readme",
  "keywords": [
    "meta",
    "metaprogramming",
    "oop",
    "toolkit",
    "utility",
    "descriptors",
    "property-descriptors",
    "aliases",
    "prototypes",
    "iterators",
    "naming-convention",
    "camelCase",
    "snake_case",
    "kebab-case",
    "deep-path",
    "comparators",
    "options",
    "zero-dependency",
    "esm"
  ],
  "author": "Eugene Lazutkin <eugene.lazutkin@gmail.com> (http://www.lazutkin.com/)",
  "license": "BSD-3-Clause",
  "files": [
    "/src",
    "llms.txt",
    "llms-full.txt"
  ],
  "tape6": {
    "tests": [
      "/tests/test-*.*js"
    ],
    "importmap": {
      "imports": {
        "tape-six": "/node_modules/tape-six/index.js",
        "meta-toolkit/": "/src/"
      }
    }
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "tape-six": "^1.7.2",
    "tape-six-proc": "^1.2.3",
    "typescript": "^5.9.3"
  }
}
